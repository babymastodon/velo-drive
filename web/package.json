{
  "name": "velodrive-web",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "VeloDrive — TypeScript + Vite + Svelte 5 PWA",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:docs": "node scripts/build-docs.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^25.9.3",
    "fast-check": "^3.23.0",
    "happy-dom": "^15.11.0",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1"
  }
}
